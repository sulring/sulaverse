{
  "$schema": "vscode://schemas/color-theme",
  "name": "Sulaverse Dark",
  "type": "dark",
  "colors": {
    "editor.background":                        "#161d2c",
    "editor.foreground":                        "#dce5f4",
    "editor.lineHighlightBackground":           "#1f252d",
    "editor.selectionBackground":               "#3d4352",
    "editor.selectionHighlightBackground":      "#3d435280",
    "editor.inactiveSelectionBackground":       "#1f252d",
    "editor.wordHighlightBackground":           "#3d435260",
    "editor.wordHighlightStrongBackground":     "#3d435290",
    "editor.findMatchBackground":               "#3d4352",
    "editor.findMatchHighlightBackground":      "#3d435270",
    "editor.rangeHighlightBackground":          "#1f252d50",
    "editorLineNumber.foreground":              "#697386",
    "editorLineNumber.activeForeground":        "#dce5f4",
    "editorCursor.foreground":                  "#dce5f4",
    "editorCursor.background":                  "#161d2c",
    "editorWhitespace.foreground":              "#505a68",
    "editorIndentGuide.background":             "#3d4352",
    "editorIndentGuide.activeBackground":       "#505a68",
    "editorRuler.foreground":                   "#3d4352",
    "editorBracketMatch.background":            "#3d4352",
    "editorBracketMatch.border":                "#9893be",
    "editorError.foreground":                   "#ec5f5f",
    "editorWarning.foreground":                 "#f5ac7a",
    "editorInfo.foreground":                    "#3d8cbd",
    "editorHint.foreground":                    "#85d2d6",
    "editorGutter.background":                  "#161d2c",
    "editorGutter.addedBackground":             "#85d2d6",
    "editorGutter.modifiedBackground":          "#f5ac7a",
    "editorGutter.deletedBackground":           "#ec5f5f",
    "editorOverviewRuler.border":               "#3d4352",
    "editorOverviewRuler.errorForeground":      "#ec5f5f",
    "editorOverviewRuler.warningForeground":    "#f5ac7a",
    "editorOverviewRuler.findMatchForeground":  "#9893be",

    "editorWidget.background":                  "#222a39",
    "editorWidget.border":                      "#505a68",
    "editorSuggestWidget.background":           "#222a39",
    "editorSuggestWidget.border":               "#505a68",
    "editorSuggestWidget.foreground":           "#8d93ab",
    "editorSuggestWidget.selectedBackground":   "#3d4352",
    "editorSuggestWidget.highlightForeground":  "#85d2d6",
    "editorHoverWidget.background":             "#222a39",
    "editorHoverWidget.border":                 "#505a68",

    "activityBar.background":                   "#1d232f",
    "activityBar.foreground":                   "#dce5f4",
    "activityBar.inactiveForeground":           "#697386",
    "activityBar.border":                       "#3d4352",
    "activityBarBadge.background":              "#9893be",
    "activityBarBadge.foreground":              "#1f252d",

    "sideBar.background":                       "#1d232f",
    "sideBar.foreground":                       "#8d93ab",
    "sideBar.border":                           "#3d4352",
    "sideBarTitle.foreground":                  "#697386",
    "sideBarSectionHeader.background":          "#161d2c",
    "sideBarSectionHeader.foreground":          "#697386",
    "sideBarSectionHeader.border":              "#3d4352",

    "list.activeSelectionBackground":           "#3d4352",
    "list.activeSelectionForeground":           "#dce5f4",
    "list.inactiveSelectionBackground":         "#1f252d",
    "list.hoverBackground":                     "#1f252d",
    "list.hoverForeground":                     "#dce5f4",
    "list.focusBackground":                     "#3d4352",
    "list.errorForeground":                     "#ec5f5f",
    "list.warningForeground":                   "#f5ac7a",
    "listFilterWidget.background":              "#222a39",
    "listFilterWidget.outline":                 "#9893be",

    "statusBar.background":                     "#1d232f",
    "statusBar.foreground":                     "#697386",
    "statusBar.border":                         "#3d4352",
    "statusBar.debuggingBackground":            "#f5ac7a",
    "statusBar.debuggingForeground":            "#1f252d",
    "statusBar.noFolderBackground":             "#1d232f",
    "statusBarItem.remoteBackground":           "#9893be",
    "statusBarItem.remoteForeground":           "#1f252d",
    "statusBarItem.hoverBackground":            "#3d4352",

    "titleBar.activeBackground":                "#1d232f",
    "titleBar.activeForeground":                "#8d93ab",
    "titleBar.inactiveBackground":              "#161d2c",
    "titleBar.inactiveForeground":              "#697386",
    "titleBar.border":                          "#3d4352",

    "tab.activeBackground":                     "#161d2c",
    "tab.activeForeground":                     "#dce5f4",
    "tab.activeBorder":                         "#9893be",
    "tab.inactiveBackground":                   "#1d232f",
    "tab.inactiveForeground":                   "#697386",
    "tab.border":                               "#3d4352",
    "tab.unfocusedActiveForeground":            "#8d93ab",
    "tab.unfocusedInactiveForeground":          "#697386",
    "editorGroupHeader.tabsBackground":         "#1d232f",
    "editorGroupHeader.noTabsBackground":       "#1d232f",
    "editorGroup.border":                       "#3d4352",

    "panel.background":                         "#161d2c",
    "panel.border":                             "#3d4352",
    "panelTitle.activeForeground":              "#dce5f4",
    "panelTitle.activeBorder":                  "#9893be",
    "panelTitle.inactiveForeground":            "#697386",

    "terminal.background":                      "#161d2c",
    "terminal.foreground":                      "#dce5f4",
    "terminal.selectionBackground":             "#3d4352",
    "terminal.ansiBlack":                       "#1f252d",
    "terminal.ansiBrightBlack":                 "#697386",
    "terminal.ansiRed":                         "#ec5f5f",
    "terminal.ansiBrightRed":                   "#ec5f5f",
    "terminal.ansiGreen":                       "#85d2d6",
    "terminal.ansiBrightGreen":                 "#85d2d6",
    "terminal.ansiYellow":                      "#f5ac7a",
    "terminal.ansiBrightYellow":                "#ecdac0",
    "terminal.ansiBlue":                        "#3d8cbd",
    "terminal.ansiBrightBlue":                  "#3d8cbd",
    "terminal.ansiMagenta":                     "#9893be",
    "terminal.ansiBrightMagenta":               "#9893be",
    "terminal.ansiCyan":                        "#85d2d6",
    "terminal.ansiBrightCyan":                  "#85d2d6",
    "terminal.ansiWhite":                       "#8d93ab",
    "terminal.ansiBrightWhite":                 "#dce5f4",

    "gitDecoration.addedResourceForeground":    "#85d2d6",
    "gitDecoration.modifiedResourceForeground": "#f5ac7a",
    "gitDecoration.deletedResourceForeground":  "#ec5f5f",
    "gitDecoration.untrackedResourceForeground":"#85d2d6",
    "gitDecoration.ignoredResourceForeground":  "#697386",
    "gitDecoration.conflictingResourceForeground":"#ec5f5f",

    "badge.background":                         "#9893be",
    "badge.foreground":                         "#1f252d",
    "button.background":                        "#9893be",
    "button.foreground":                        "#1f252d",
    "button.hoverBackground":                   "#8d93ab",
    "button.secondaryBackground":               "#3d4352",
    "button.secondaryForeground":               "#dce5f4",
    "input.background":                         "#222a39",
    "input.border":                             "#3d4352",
    "input.foreground":                         "#dce5f4",
    "input.placeholderForeground":              "#697386",
    "inputOption.activeBorder":                 "#9893be",
    "inputValidation.errorBorder":              "#ec5f5f",
    "inputValidation.warningBorder":            "#f5ac7a",
    "inputValidation.infoBorder":               "#3d8cbd",
    "focusBorder":                              "#9893be",
    "selection.background":                     "#3d4352",
    "descriptionForeground":                    "#8d93ab",
    "errorForeground":                          "#ec5f5f",
    "icon.foreground":                          "#8d93ab",
    "foreground":                               "#dce5f4",
    "widget.shadow":                            "#00000040",
    "scrollbar.shadow":                         "#00000030",
    "scrollbarSlider.background":               "#505a6880",
    "scrollbarSlider.hoverBackground":          "#697386",
    "scrollbarSlider.activeBackground":         "#697386",
    "dropdown.background":                      "#222a39",
    "dropdown.border":                          "#3d4352",
    "dropdown.foreground":                      "#dce5f4",
    "menu.background":                          "#222a39",
    "menu.foreground":                          "#dce5f4",
    "menu.selectionBackground":                 "#3d4352",
    "menu.separatorBackground":                 "#3d4352",
    "menubar.selectionBackground":              "#3d4352",
    "notifications.background":                 "#222a39",
    "notifications.border":                     "#505a68",
    "notificationLink.foreground":              "#3d8cbd",
    "peekView.border":                          "#9893be",
    "peekViewEditor.background":                "#1f252d",
    "peekViewResult.background":                "#1d232f",
    "peekViewResult.selectionBackground":       "#3d4352",
    "peekViewResult.matchHighlightBackground":  "#3d435270",
    "keybindingLabel.background":               "#3d4352",
    "keybindingLabel.foreground":               "#dce5f4",
    "keybindingLabel.border":                   "#505a68"
  },
  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "foreground": "#697386", "fontStyle": "italic" }
    },
    {
      "scope": ["string", "string.quoted", "string.template"],
      "settings": { "foreground": "#85d2d6" }
    },
    {
      "scope": ["string.escape", "constant.character.escape"],
      "settings": { "foreground": "#3d8cbd" }
    },
    {
      "scope": ["constant.numeric", "constant.language.boolean", "constant.language.null", "constant.language.undefined"],
      "settings": { "foreground": "#f5ac7a" }
    },
    {
      "scope": ["constant.language", "constant.other"],
      "settings": { "foreground": "#f5ac7a" }
    },
    {
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#9893be", "fontStyle": "bold" }
    },
    {
      "scope": ["keyword.operator", "keyword.control.flow"],
      "settings": { "foreground": "#9893be" }
    },
    {
      "scope": ["keyword.return", "keyword.control.return"],
      "settings": { "foreground": "#ec5f5f" }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call entity.name.function"],
      "settings": { "foreground": "#3d8cbd" }
    },
    {
      "scope": ["entity.name.class", "entity.name.type", "entity.name.namespace", "support.class", "entity.other.inherited-class"],
      "settings": { "foreground": "#ecdac0" }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": { "foreground": "#ec5f5f" }
    },
    {
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#f5ac7a" }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": { "foreground": "#dce5f4" }
    },
    {
      "scope": ["variable.other.constant"],
      "settings": { "foreground": "#f5ac7a" }
    },
    {
      "scope": ["support.type", "support.class"],
      "settings": { "foreground": "#ecdac0" }
    },
    {
      "scope": ["support.type.property-name", "variable.other.property", "variable.other.object.property"],
      "settings": { "foreground": "#dce5f4" }
    },
    {
      "scope": ["meta.import", "keyword.control.import", "keyword.control.from"],
      "settings": { "foreground": "#3d8cbd" }
    },
    {
      "scope": ["punctuation.definition", "punctuation.separator", "punctuation.terminator"],
      "settings": { "foreground": "#8d93ab" }
    },
    {
      "scope": ["invalid"],
      "settings": { "foreground": "#ec5f5f", "fontStyle": "underline" }
    },
    {
      "scope": ["markup.bold"],
      "settings": { "fontStyle": "bold" }
    },
    {
      "scope": ["markup.italic"],
      "settings": { "fontStyle": "italic" }
    },
    {
      "scope": ["markup.heading"],
      "settings": { "foreground": "#dce5f4", "fontStyle": "bold" }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block"],
      "settings": { "foreground": "#85d2d6" }
    },
    {
      "scope": ["markup.underline.link"],
      "settings": { "foreground": "#3d8cbd", "fontStyle": "underline" }
    },
    {
      "scope": ["markup.quote"],
      "settings": { "foreground": "#8d93ab", "fontStyle": "italic" }
    },
    {
      "scope": ["markup.inserted"],
      "settings": { "foreground": "#85d2d6" }
    },
    {
      "scope": ["markup.deleted"],
      "settings": { "foreground": "#ec5f5f" }
    },
    {
      "scope": ["markup.changed"],
      "settings": { "foreground": "#f5ac7a" }
    }
  ]
}
